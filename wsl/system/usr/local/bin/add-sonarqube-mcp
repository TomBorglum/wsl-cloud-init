#!/bin/bash
# add-sonarqube-mcp: enable the SonarQube Cloud MCP server for the CURRENT project, so
# Claude Code can read and fix Sonar issues for that repo — including private repos whose
# SonarCloud dashboards aren't publicly reachable.
#
# Installed with -InstallClaudeCode (see 15-install-add-sonarqube-mcp.sh) but dormant until
# you run it. Run it from inside the project directory you want to enable it for. It writes
# two committed-friendly, SECRET-FREE files:
#
#   .mcp.json  a project-scoped MCP server whose env references ${SONARQUBE_TOKEN:-} /
#              ${SONARQUBE_ORG:-} rather than embedding secrets, so it is safe to commit and
#              share with your team.
#   .envrc     a guarded one-liner that lets direnv populate those variables from Windows
#              Credential Manager (via the provisioned sonarqube_mcp_env direnv lib).
#
# The token and org therefore never touch disk in the project; each developer keeps their
# own wsl-cloud-init:SONARQUBE_TOKEN / wsl-cloud-init:SONARQUBE_ORG in Windows Credential
# Manager, and direnv injects them at Claude launch time (a no-op in CI / off-WSL).
#
# The Sonar MCP server is a stdio server run via Docker (installed at 02-install-docker.sh;
# the user is in the docker group). The pinned image is pre-warmed here; Docker's default
# pull-if-missing re-pulls it automatically if it is later removed.

set -euo pipefail

# Pinned image tag for reproducibility; bump deliberately. See:
# https://hub.docker.com/r/sonarsource/sonarqube-mcp/tags
IMAGE="sonarsource/sonarqube-mcp:1.22.0.3040"

# The guarded line appended to .envrc. The `declare -f` guard keeps .envrc portable: on any
# machine without the provisioned direnv lib (notably CI) it is simply a no-op.
ENVRC_LINE='if declare -f sonarqube_mcp_env >/dev/null 2>&1; then sonarqube_mcp_env; fi'

usage() {
  cat >&2 <<EOF
Usage: add-sonarqube-mcp [-y|--yes]

Enable the SonarQube Cloud MCP server for the current project: write a secret-free
./.mcp.json plus a guarded ./.envrc line (both safe to commit). direnv then supplies
SONARQUBE_TOKEN / SONARQUBE_ORG from Windows Credential Manager at Claude launch time.

  -y, --yes    skip the confirmation prompt
  -h, --help   show this help
EOF
}

# Best-effort reminder that the credentials direnv will read exist. Only possible where the
# interop bundle is available; never fatal — the generated files are valid regardless.
warn_missing_credentials() {
  [[ -x "${POWERSHELL:-}" && -f /usr/local/lib/wsl-cloud-init/wsl-interop.sh ]] || return 0
  source /usr/local/lib/wsl-cloud-init/wsl-interop.sh
  local name missing=0
  for name in SONARQUBE_TOKEN SONARQUBE_ORG; do
    if [[ -z "$(wsl_interop_credential "wsl-cloud-init:$name" 2>/dev/null || true)" ]]; then
      echo "  note: 'wsl-cloud-init:$name' is not set in Windows Credential Manager yet." >&2
      echo "        Add it on Windows (PowerShell): cmdkey /generic:wsl-cloud-init:$name /user:wsl-cloud-init /pass:<value>" >&2
      missing=1
    fi
  done
  [[ $missing -eq 0 ]] || echo "        Claude reads these via direnv; set them so the sonarqube server can authenticate." >&2
}

assume_yes=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    -y|--yes) assume_yes=true; shift ;;
    --) shift; break ;;
    *) echo "add-sonarqube-mcp: unknown argument: $1" >&2; usage; exit 1 ;;
  esac
done

if ! command -v claude >/dev/null 2>&1; then
  echo "add-sonarqube-mcp: 'claude' not found on PATH — provision with -InstallClaudeCode first." >&2
  exit 1
fi

# Skip if already registered. This is an *add* command: it never updates an existing entry
# (refreshing after a token rotation or image bump is left to a future dedicated command).
if [[ -f .mcp.json ]] && jq -e '.mcpServers.sonarqube' .mcp.json >/dev/null 2>&1; then
  echo "add-sonarqube-mcp: a 'sonarqube' MCP server is already registered in ./.mcp.json — leaving it unchanged." >&2
  echo "  To re-register, first remove it: claude mcp remove sonarqube --scope project" >&2
  exit 0
fi

# Confirm before writing into the current directory (the project we're enabling).
if [[ "$assume_yes" != true ]]; then
  printf 'Write ./.mcp.json and ./.envrc to enable SonarQube MCP in %s? [y/N] ' "$PWD" >&2
  read -r reply || reply=""
  case "$reply" in
    [yY]|[yY][eE][sS]) ;;
    *) echo "Aborted." >&2; exit 1 ;;
  esac
fi

# Pre-warm the pinned image (Docker re-pulls automatically if it is later removed).
if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
  echo "Pulling $IMAGE..." >&2
  docker pull "$IMAGE"
fi

# Write the secret-free server via the CLI (creates/merges ./.mcp.json). The single-quoted
# ${...:-} strings are stored verbatim and expanded by Claude at launch from direnv's env;
# the :- empty default means the file still parses when a var is unset, so an unconfigured
# clone degrades to just this server being inert rather than a broken .mcp.json.
claude mcp add sonarqube --scope project \
  --env 'SONARQUBE_TOKEN=${SONARQUBE_TOKEN:-}' \
  --env 'SONARQUBE_ORG=${SONARQUBE_ORG:-}' \
  -- docker run --init -i --rm -e SONARQUBE_TOKEN -e SONARQUBE_ORG "$IMAGE"

# Ensure the guarded direnv line is present in ./.envrc (append, never clobber an existing
# .envrc; skip if already there so re-running is idempotent).
if [[ ! -f .envrc ]] || ! grep -qF 'sonarqube_mcp_env' .envrc; then
  printf '%s\n' "$ENVRC_LINE" >> .envrc
  echo "Added the SonarQube direnv line to ./.envrc." >&2
fi

echo "" >&2
echo "Enabled the 'sonarqube' MCP server in $PWD (./.mcp.json + ./.envrc)." >&2
echo "Both files are secret-free and safe to commit and share." >&2
echo "Next: run 'direnv allow' to activate it in this shell." >&2
warn_missing_credentials
