#!/bin/bash
# zed wrapper: opens files/folders in the Windows Zed editor from inside WSL.
#
# Resolves Zed's WSL-aware `zed` shell launcher via the shared wsl_interop_zed_launcher
# helper (all the PowerShell lives in wsl-interop.sh), using $POWERSHELL from the environment
# (exported from ~/.zshenv, derived once in install.sh). The launcher path is cached under the
# user's cache dir after the first resolve, so most launches skip the ~1s interop roundtrip; it
# re-resolves automatically if the cached path stops existing (Zed moved/reinstalled). Nothing
# is persisted to the shell environment — mirroring the open/gh wrappers.
#
# ConvertTo-WslPath returns the /mnt path with backslash-escaped spaces (a Windows
# username may contain them), so the launcher is handed to `eval` rather than
# expanded directly: eval re-parses the escape into a single argv[0], the way
# sourcing an `export ZED=...` line once did — but correctly, since an unquoted
# $ZED would have word-split on the space.
set -euo pipefail

source /usr/local/lib/wsl-cloud-init/wsl-interop.sh

launcher="$(wsl_interop_zed_launcher)"   # cached; set -e exits here if resolution fails
eval "$launcher" '"$@"'
