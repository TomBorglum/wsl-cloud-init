#!/bin/bash
# code wrapper: opens files/folders in the Windows VS Code editor from inside WSL.
#
# Resolves VS Code's WSL-aware `code` shell launcher on each invocation via the shared
# wsl_interop_vscode_path helper (all the PowerShell lives in wsl-interop.sh), using
# $POWERSHELL from the environment (exported from ~/.zshenv, derived once in
# install.sh). Nothing is baked in and no per-editor value is persisted — mirroring
# the open/gh wrappers.
#
# ConvertTo-WslPath returns the /mnt path with backslash-escaped spaces (a Windows
# username may contain them), so the launcher is handed to `eval` rather than
# expanded directly: eval re-parses the escape into a single argv[0], the way
# sourcing an `export VSCODE=...` line once did — but correctly, since an unquoted
# $VSCODE would have word-split on the space.
set -euo pipefail

source /usr/local/lib/wsl-cloud-init/wsl-interop.sh

launcher="$(wsl_interop_vscode_path)"   # set -e exits here if resolution fails
eval "$launcher" '"$@"'
